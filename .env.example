# ─────────────────────────────────────────────────────────────────
# Anderson Report Automation – Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
# Public URL of the server (used for QR codes in reports)
APP_BASE_URL=http://your-server-ip-or-domain:8000

# ── Frontend directory (leave blank to auto-detect) ───────────────
# FRONTEND_DIR=/path/to/frontend

# ── MySQL Database (OPTIONAL) ─────────────────────────────────────
# Leave blank to skip database logging. Reports are always saved locally.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
