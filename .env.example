# ─────────────────────────────────────────────────────────────────
# Anderson Report Automation – Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
# Public URL of the server (used for QR codes in reports)
APP_BASE_URL=http://your-server-ip-or-domain:8000

# ── Frontend directory (leave blank to auto-detect) ───────────────
# FRONTEND_DIR=/path/to/frontend

# ── MySQL Database (OPTIONAL) ─────────────────────────────────────
# Leave blank to skip database logging. Reports are always saved locally.
# Also backs the Admin page's per-report access control: maps an
# already-IT-verified username to a role + single report. No local
# password is stored/checked here anymore — see GENETICS_API_* below.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# ── IT genetics auth gateway (login + OTP) ────────────────────────
# Service-account credentials IT gave you for /auth/login — this token
# authenticates the server itself when calling /genetics/login and
# /genetics/verify_otp on behalf of end users. Required for login to work.
GENETICS_API_BASE=https://integration.andrsn.in
GENETICS_API_USERNAME=
GENETICS_API_PASSWORD=
